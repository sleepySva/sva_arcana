	  "children" : {
		"tabLabel_1" : {
		  "type" : "label",
		  "position" : [24, 240],
		  "hAnchor" : "left",
		  "value" : "^orange;Arcana v1.4.2, Elegy of The Nightfaeries^#ffffff;",
		  "zlevel" : 3
		},
	  	"back_1" : {
          "type" : "image",
		  "position" : [16, 237],
          "file" : "/interface/scripted/arcana_updates/pheader.png",
